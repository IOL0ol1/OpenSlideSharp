--additional
-m64
--language
c
--config
#exclude-com-proxies
exclude-empty-records
#exclude-enum-operators
generate-aggressive-inlining
generate-callconv-member-function
generate-cpp-attributes
generate-disable-runtime-marshalling 
generate-macro-bindings
generate-marker-interfaces
generate-native-inheritance-attribute
generate-setslastsystemerror-attribute
#generate-tests-nunit
generate-unmanaged-constants
log-potential-typedef-remappings
#multi-file
single-file
#preview-codegen
compatible-codegen
unix-types
--define-macro
OPENSLIDE_SIMPLIFY_HEADERS
--exclude
OPENSLIDE_DEPRECATED
OPENSLIDE_DEPRECATED_FOR
OPENSLIDE_PUBLIC 
--file-directory
./openslide/include/openslide
--file
openslide.h
#--headerFile
#./openslide/GenerateOpenSlide-LICENSE.txt
--include-directory
./openslide/include/openslide
--libraryPath
libopenslide-1
--methodClassName
openslide
--namespace
OpenSlideSharp.Interop
--output
../src/OpenSlideSharp.Interop/OpenSlide.Interop.cs
--prefixStrip
openslide_
--remap 
_openslide*=@IntPtr 
_openslide_cache*=@IntPtr
char=byte
bool=byte
void*=@IntPtr
#--test-output
#../tests/OpenSlide.UnitTests/InteropTests.cs
